{
  "name": "finn-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "build:android": "turbo -F native build:android",
    "build:android:aab": "turbo -F native build:android:aab",
    "build:android:apk:arm64": "turbo -F native build:android:apk:arm64",
    "build:android:apk:universal": "turbo -F native build:android:apk:universal",
    "build:android:dev": "turbo -F native build:android:dev",
    "docker:db:up": "docker run --rm --name fin-app-db -p 5432:5432 -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=finapp -v fin-app-db-data:/var/lib/postgresql/data postgres:17-alpine",
    "docker:build:server": "docker build -t fin-app-server:railway .",
    "docker:migrate": "docker build --target migrate -t fin-app-db-migrate . && docker run --rm --add-host=host.docker.internal:host-gateway --env-file apps/server/.env fin-app-db-migrate",
    "docker:run:server": "docker run --rm --name fin-app-server -p 3000:3000 --add-host=host.docker.internal:host-gateway --env-file apps/server/.env -v ./secret-config:/app/secret-config:ro fin-app-server:railway",
    "docker:start:server": "docker run -d --name fin-app-server -p 3000:3000 --add-host=host.docker.internal:host-gateway --env-file apps/server/.env -v ./secret-config:/app/secret-config:ro fin-app-server:railway",
    "docker:stop:server": "docker stop fin-app-server",
    "db:push": "turbo -F @finn-app/db db:push",
    "db:studio": "turbo -F @finn-app/db db:studio",
    "db:generate": "turbo -F @finn-app/db db:generate",
    "db:migrate": "turbo -F @finn-app/db db:migrate",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@finn-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@finn-app/config": "workspace:*",
    "@types/node": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  },
  "packageManager": "pnpm@11.5.2"
}
